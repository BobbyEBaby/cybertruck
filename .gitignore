# Credentials and secrets — never commit
.env
.env.*
secrets/
*.key
*.pem
*.token

# Build artifacts
node_modules/
dist/
build/
__pycache__/
*.pyc
.DS_Store

# Local-only state
human_outbox/processed/
human_inbox/processed/
*.local.md

# Large derived video artifacts (rebuildable from script + images + tools)
experiments/youtube-history-channel/assets/**/final.mp4

# Obsidian workspace config (user-specific, not project config)
.obsidian/workspace*
.obsidian/cache
.obsidian/graph.json
.obsidian/hotkeys.json

# Playwright MCP session artifacts (local-only browser snapshots + screenshots)
.playwright-mcp/
*.png
!experiments/**/*.png
!wiki/**/*.png
